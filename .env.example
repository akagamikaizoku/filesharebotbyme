# Telegram Bot Configuration
TG_BOT_TOKEN=your_bot_token_here
APP_ID=your_app_id_here
API_HASH=your_api_hash_here

# Channel Configuration
CHANNEL_ID=your_database_channel_id
OWNER_ID=your_telegram_user_id

# Database Configuration
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=filesharexbot

# Optional: Force Subscription
FORCE_SUB_CHANNEL=0

# Optional: Bot Workers
TG_BOT_WORKERS=4

# Optional: Port (for Koyeb/Railway)
PORT=8080

# Optional: Custom Messages
START_MESSAGE=Hello {first}!\n\nI'm a File Sharing Bot. Send me files and I'll generate secure shareable links.\n\nUse /help to see all available commands.\n\nThanks for using me!

FORCE_SUB_MESSAGE=Hello {first}\n\n<b>You need to join in my Channel/Group to use me\n\nKindly Please join Channel</b>

# Optional: Custom Caption
CUSTOM_CAPTION=

# Optional: Protect Content (prevent forwarding)
PROTECT_CONTENT=False

# Optional: Disable Channel Button
DISABLE_CHANNEL_BUTTON=False

# Admin User IDs (space separated)
ADMINS=your_admin_id_1 your_admin_id_2
